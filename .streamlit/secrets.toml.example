# 部署到 Streamlit Cloud 時，把這個檔案的內容貼到
# Streamlit Cloud → App settings → Secrets

ANTHROPIC_API_KEY = "sk-ant-xxx"
APIFY_API_TOKEN = "apify_api_xxx"
BYCRAWL_API_KEY = "sk_byc_xxx"

# Google OAuth（登入用）
# 到 Google Cloud Console → APIs & Services → Credentials 取得
# Authorized JavaScript origins 要加上你的 Streamlit Cloud 網址
GOOGLE_CLIENT_ID = "xxxxxxxx.apps.googleusercontent.com"

# Storm Media 後台 API
ADMIN_API = "https://your-admin-api.example.com/"
